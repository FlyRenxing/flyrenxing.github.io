---
import Base from '../layouts/Base.astro';
import Search from '../components/Search.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '../config';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="技术博客 - 分享技术见解与生活感悟" description="使用 Astro 6.0 + AI 增强的博客系统">
  <!-- Header -->
  <header class="flex justify-between items-center mb-8 md:mb-16">
    <div class="text-xs font-mono uppercase tracking-widest text-slate-400 dark:text-zinc-500">
      {SITE_CONFIG.siteName} // <span class="text-slate-900 dark:text-zinc-100">Blog</span>
    </div>
    <Search />
  </header>

  <!-- Timeline -->
  <section>
    <h2 class="text-xl font-semibold mb-6 md:mb-8">时间线</h2>

    <div class="relative pl-6 md:pl-8 before:absolute before:left-[7px] before:top-0 before:bottom-0 before:w-0.5 before:bg-gradient-to-b before:from-violet-600 before:to-slate-200 dark:before:to-zinc-700">
      {posts.map((post) => (
        <article class="relative pb-5 md:pb-6 last:pb-0 group">
          <!-- Marker -->
          <div class="absolute -left-6 md:-left-8 top-1 w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-violet-600 border-2 border-white dark:border-zinc-950 shadow-[0_0_0_2px_#6528F7] z-10"></div>

          <!-- Content Card -->
          <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class={`block rounded-xl md:rounded-2xl p-4 md:p-5 transition-all duration-300 hover:shadow-lg hover:-translate-x-1 ${post.data.heroImage ? 'relative overflow-hidden' : 'bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800'}`}>
            {/* Hero Image Background */}
            {post.data.heroImage && (
              <div class="absolute inset-0 z-0">
                <img
                  src={post.data.heroImage}
                  alt=""
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                {/* Gradient Overlay */}
                <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-slate-900/50 dark:from-zinc-950/90 dark:via-zinc-950/70 dark:to-zinc-950/50"></div>
                {/* Liquid Glass Effect */}
                <div class="absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent dark:from-white/5"></div>
                {/* Animated Gradient Border */}
                <div class="absolute inset-0 rounded-xl md:rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(135deg, rgba(167, 139, 250, 0.4), transparent 50%, rgba(167, 139, 250, 0.2)); backdrop-filter: blur(1px);"></div>
              </div>
            )}

            {/* Card Content */}
            <div class={`relative z-10 ${post.data.heroImage ? 'text-white' : 'bg-white dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 -m-4 md:-m-5 p-4 md:p-5 rounded-xl md:rounded-2xl'}`}>
              <div class="flex flex-wrap items-center gap-2 md:gap-3 mb-2">
                <time datetime={post.data.pubDate.toISOString()} class={`text-xs md:text-sm font-medium ${post.data.heroImage ? 'text-white/70' : 'text-slate-400 dark:text-zinc-500'}`}>
                  {post.data.pubDate.toLocaleDateString('zh-CN')}
                </time>
                {post.data.aiGenerated && (
                  <span class="text-xs px-1.5 md:px-2 py-0.5 bg-gradient-to-r from-indigo-500 to-purple-600 text-white rounded font-medium">AI</span>
                )}
              </div>
              <h3 class={`text-base md:text-lg font-semibold mb-1.5 md:mb-2 ${post.data.heroImage ? 'text-white' : 'text-slate-900 dark:text-zinc-100'}`}>{post.data.title}</h3>
              <p class={`text-xs md:text-sm line-clamp-2 mb-2 md:mb-3 ${post.data.heroImage ? 'text-white/80' : 'text-slate-500 dark:text-zinc-400'}`}>{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex gap-1.5 md:gap-2 flex-wrap">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class={`text-xs px-1.5 md:px-2 py-0.5 rounded ${post.data.heroImage ? 'bg-white/20 text-white backdrop-blur-sm' : 'text-violet-600 bg-violet-50 dark:bg-violet-950 dark:text-violet-400'}`}>#{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</Base>